<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ companion_name }}的房间 · 共生境</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body,html{width:100%;height:100%;overflow:hidden;background:#0a0a0a}
body{display:flex;align-items:center;justify-content:center}
canvas{display:block}
#loading{position:fixed;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;background:#0a0a0a;z-index:9999;transition:opacity 1.2s}
#loading.hide{opacity:0;pointer-events:none}
.load-title{font-size:20px;font-weight:800;color:#f4d08a;margin-top:16px;letter-spacing:3px;font-family:sans-serif}
.load-sub{font-size:11px;color:rgba(255,255,255,0.35);margin-top:6px;font-family:sans-serif}
.load-bar{width:140px;height:3px;background:rgba(255,255,255,0.1);border-radius:2px;margin-top:16px;overflow:hidden}
.load-fill{height:100%;background:linear-gradient(90deg,#ffd740,#ff8c00);border-radius:2px;animation:loadAnim 1.5s ease-in-out infinite}
@keyframes loadAnim{0%{width:0%}50%{width:100%}100%{width:0%}}

/* UI */
.ui-top{position:fixed;top:16px;left:50%;transform:translateX(-50%);z-index:100;pointer-events:none}
.ui-top-inner{display:flex;align-items:center;gap:10px;background:rgba(255,255,255,0.97);border-radius:28px;padding:6px 10px 6px 8px;box-shadow:0 4px 24px rgba(0,0,0,0.25)}
.back-btn{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#f0f0f0,#e4e4e4);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:15px;color:#5a7a9a;text-decoration:none;flex-shrink:0}
.ri{font-size:14px;font-weight:800;color:#1a3a52}
.rs{font-size:11px;color:#8aa0b8}
.dot{width:8px;height:8px;border-radius:50%;background:#4ade80;box-shadow:0 0 6px #4ade80}
.ot{font-size:11px;color:#6a8aaa;font-weight:600}

.ui-companion{position:fixed;bottom:90px;left:50%;transform:translateX(-50%);display:flex;gap:8px;z-index:100}
.ca{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;cursor:pointer;border:2px solid transparent;text-decoration:none;transition:all 0.2s;flex-shrink:0}
.ca:hover{transform:scale(1.08)}
.ca.on{border-color:#ffd740;transform:scale(1.1)}

.chat-bar{position:fixed;bottom:0;left:0;right:0;background:linear-gradient(to top,rgba(8,6,4,0.98),rgba(12,10,8,0.97));backdrop-filter:blur(24px);padding:12px 16px 24px;z-index:100;border-top:1px solid rgba(255,255,255,0.05)}
.chat-inner{display:flex;gap:10px;align-items:flex-end;max-width:700px;margin:0 auto}
.chat-msgs{flex:1;max-height:52px;overflow-y:auto;display:flex;flex-direction:column;gap:4px;padding:10px 14px;background:rgba(255,255,255,0.05);border-radius:20px;border:1px solid rgba(255,255,255,0.08)}
.msg{font-size:13px;line-height:1.4}
.msg.ai .mt{color:rgba(255,255,255,0.88)}
.msg.user .mt{color:#ffd740}
.chat-input{flex:1;padding:12px 16px;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);border-radius:20px;color:#fff;font-size:14px;font-family:inherit;outline:none;transition:border-color 0.2s;min-width:0}
.chat-input::placeholder{color:rgba(255,255,255,0.3)}
.chat-input:focus{border-color:rgba(255,215,0,0.35)}
.chat-send{width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,#ffd740,#ffa000);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:18px;color:#1a3a52;transition:all 0.2s;flex-shrink:0;box-shadow:0 4px 14px rgba(255,200,0,0.3)}
.chat-send:hover{transform:scale(1.05)}
</style>
</head>
<body>

<div id="loading">
  <div style="font-size:48px">{{ companion_emoji }}</div>
  <div class="load-title">正在加载 {{ companion_name }}的房间...</div>
  <div class="load-bar"><div class="load-fill"></div></div>
  <div class="load-sub">{{ companion_personality }}</div>
</div>

<canvas id="c"></canvas>

<div class="ui-top">
  <div class="ui-top-inner">
    <a href="/" class="back-btn">←</a>
    <div id="avaIcon" style="width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px"></div>
    <div><div class="ri">{{ companion_name }}的房间</div><div class="rs">{{ companion_personality }}</div></div>
    <div style="width:1px;height:20px;background:rgba(26,58,82,0.1);margin:0 2px"></div>
    <div class="dot"></div>
    <div class="ot">在线</div>
  </div>
</div>

<div class="ui-companion">
  <div class="ca on" id="ca_luna" style="background:linear-gradient(135deg,#FFB6C1,#FF69B4)">🌙</div>
  <a href="/room/kai" class="ca" id="ca_kai" style="background:linear-gradient(135deg,#4169E1,#1E90FF)">🌊</a>
  <a href="/room/nova" class="ca" id="ca_nova" style="background:linear-gradient(135deg,#FF8C00,#FFD700)">⭐</a>
  <a href="/room/milo" class="ca" id="ca_milo" style="background:linear-gradient(135deg,#228B22,#32CD32)">🌿</a>
  <a href="/room/sage" class="ca" id="ca_sage" style="background:linear-gradient(135deg,#8B4513,#D2691E)">📚</a>
</div>

<div class="chat-bar">
  <div class="chat-inner">
    <div class="chat-msgs" id="chatMsgs">
      <div class="msg ai"><span class="mt">欢迎来到我的小窝～ 这里是不是很温馨？随便坐吧～</span></div>
    </div>
    <input class="chat-input" id="chatInput" placeholder="和 {{ companion_name }} 说点什么..." onkeydown="if(event.key==='Enter')sendMsg()">
    <button class="chat-send" onclick="sendMsg()">→</button>
  </div>
</div>

<script src="https://unpkg.com/three@0.158.0/build/three.min.js"></script>
<script>
// ══════════════════════════════════════════════════════════════
// ROOM CONFIGURATIONS — each companion has unique style
// ══════════════════════════════════════════════════════════════
var COMP = '{{ companion_id }}';
var COMP_CONFIG = {
  luna: {
    bg: 0xfff8f4,
    fogColor: 0xfff8f4,
    fogDensity: 0.0008,
    floorColor: 0xf0e8e0,
    wallLColor: 0xffffff,
    wallRColor: 0xfff8f0,
    wallLAccent: 0xffe8f0,
    ambientColor: 0xfff8f4,
    ambientIntensity: 0.9,
    sunColor: 0xfff8e8,
    sunIntensity: 2.0,
    sunX: -40, sunY: 300, sunZ: -60,
    rimColor: 0xffd8a0,
    rimIntensity: 1.2,
    theme: '温柔粉调',
    greeting: '欢迎来到我的小窝～ 🌙 这里是不是很温馨？'
  },
  kai: {
    bg: 0xe8efff,
    fogColor: 0xe8efff,
    fogDensity: 0.0008,
    floorColor: 0xd0d8e8,
    wallLColor: 0xffffff,
    wallRColor: 0xf0f4ff,
    wallLAccent: 0xd0e0ff,
    ambientColor: 0xe0e8ff,
    ambientIntensity: 0.8,
    sunColor: 0xc0d0ff,
    sunIntensity: 1.8,
    sunX: -100, sunY: 280, sunZ: -80,
    rimColor: 0x6080ff,
    rimIntensity: 1.5,
    theme: '赛博极客',
    greeting: '欢迎来到我的空间，Kai在这里等你。 🌊'
  },
  nova: {
    bg: 0xfff8f0,
    fogColor: 0xfff8f0,
    fogDensity: 0.0008,
    floorColor: 0xffe8c0,
    wallLColor: 0xffffff,
    wallRColor: 0xfff8f0,
    wallLAccent: 0xffd080,
    ambientColor: 0xfff8f0,
    ambientIntensity: 0.95,
    sunColor: 0xffe8a0,
    sunIntensity: 2.2,
    sunX: 0, sunY: 300, sunZ: -50,
    rimColor: 0xffb040,
    rimIntensity: 1.3,
    theme: '活力金橙',
    greeting: '能量满满！⭐ 准备好和我一起冲刺了吗？'
  },
  milo: {
    bg: 0xf0fff0,
    fogColor: 0xf0fff0,
    fogDensity: 0.0008,
    floorColor: 0xd8f0d8,
    wallLColor: 0xffffff,
    wallRColor: 0xf8fff8,
    wallLAccent: 0xa0e8a0,
    ambientColor: 0xe8fff0,
    ambientIntensity: 0.88,
    sunColor: 0xd0ffd0,
    sunIntensity: 1.9,
    sunX: -60, sunY: 280, sunZ: -70,
    rimColor: 0x80e8a0,
    rimIntensity: 1.1,
    theme: '自然薄荷',
    greeting: '平和如风，🌿 来这里放松一下吧～'
  },
  sage: {
    bg: 0xfffaf0,
    fogColor: 0xfffaf0,
    fogDensity: 0.0008,
    floorColor: 0xe8d8c0,
    wallLColor: 0xffffff,
    wallRColor: 0xfff8f0,
    wallLAccent: 0xf0e0d0,
    ambientColor: 0xfff8f0,
    ambientIntensity: 0.85,
    sunColor: 0xffe8c0,
    sunIntensity: 1.8,
    sunX: 50, sunY: 280, sunZ: -60,
    rimColor: 0xffa060,
    rimIntensity: 1.0,
    theme: '复古书香',
    greeting: '书中有黄金屋，📚 欢迎来到我的书房～'
  }
};

var CFG = COMP_CONFIG[COMP] || COMP_CONFIG.luna;

// Avatar color
var avaColors = {
  luna: 'linear-gradient(135deg,#FFB6C1,#FF69B4)',
  kai: 'linear-gradient(135deg,#4169E1,#1E90FF)',
  nova: 'linear-gradient(135deg,#FF8C00,#FFD700)',
  milo: 'linear-gradient(135deg,#228B22,#32CD32)',
  sage: 'linear-gradient(135deg,#8B4513,#D2691E)'
};
var avatars = {'luna':'🌙','kai':'🌊','nova':'⭐','milo':'🌿','sage':'📚'};
var names = {'luna':'Luna','kai':'Kai','nova':'Nova','milo':'Milo','sage':'Sage'};

document.getElementById('avaIcon').style.background = avaColors[COMP] || avaColors.luna;
document.getElementById('avaIcon').textContent = avatars[COMP] || '🌙';
// Mark active companion
['luna','kai','nova','milo','sage'].forEach(function(c){
  var el=document.getElementById('ca_'+c);
  if(el) el.classList.remove('on');
});
var activeEl=document.getElementById('ca_'+COMP);
if(activeEl) activeEl.classList.add('on');

// ── THREE.JS SETUP ──
var canvas=document.getElementById('c');
var renderer=new THREE.WebGLRenderer({canvas,antialias:true,alpha:false});
renderer.setPixelRatio(Math.min(devicePixelRatio,2));
renderer.shadowMap.enabled=true;
renderer.shadowMap.type=THREE.PCFSoftShadowMap;
renderer.toneMapping=THREE.ACESFilmicToneMapping;
renderer.toneMappingExposure=1.05;
renderer.setClearColor(new THREE.Color(CFG.bg));

var scene=new THREE.Scene();
scene.fog=new THREE.FogExp2(CFG.fogColor, CFG.fogDensity);

// Camera
var viewSize=200;
var aspect=innerWidth/innerHeight;
var camera=new THREE.OrthographicCamera(
  -viewSize*aspect, viewSize*aspect,
  viewSize, -viewSize, 1, 2000
);
camera.position.set(260,230,260);
camera.lookAt(0,35,0);
camera.updateProjectionMatrix();

function resize(){
  var w=innerWidth, h=innerHeight;
  renderer.setSize(w,h);
  var asp=w/h;
  camera.left=-viewSize*asp; camera.right=viewSize*asp;
  camera.top=viewSize; camera.bottom=-viewSize;
  camera.updateProjectionMatrix();
}
resize();
window.addEventListener('resize',resize);

// ── LIGHTS ──
var ambient=new THREE.AmbientLight(CFG.ambientColor,CFG.ambientIntensity);
scene.add(ambient);

var sun=new THREE.DirectionalLight(CFG.sunColor,CFG.sunIntensity);
sun.position.set(CFG.sunX,CFG.sunY,CFG.sunZ);
sun.castShadow=true;
sun.shadow.mapSize.set(2048,2048);
sun.shadow.camera.left=-220; sun.shadow.camera.right=220;
sun.shadow.camera.top=220; sun.shadow.camera.bottom=-220;
sun.shadow.camera.far=500;
sun.shadow.bias=-0.0003;
scene.add(sun);

var fill=new THREE.DirectionalLight(0xffeedd,0.25);
fill.position.set(80,100,100);
scene.add(fill);

var rim=new THREE.PointLight(CFG.rimColor,CFG.rimIntensity,300);
rim.position.set(0,150,-50);
scene.add(rim);

// ── MATERIAL HELPERS ──
function mat(color, opts){
  opts = opts || {};
  var m = new THREE.MeshLambertMaterial({color: color});
  if(opts.emissive) m.emissive = new THREE.Color(opts.emissive);
  if(opts.emissiveIntensity) m.emissiveIntensity = opts.emissiveIntensity;
  if(opts.transparent) { m.transparent = true; m.opacity = opts.opacity || 0.5; }
  if(opts.side) m.side = opts.side;
  return m;
}
function box(w,h,d,color,opts){
  return new THREE.Mesh(new THREE.BoxGeometry(w,h,d), mat(color,opts));
}
function cyl(rt,rb,h,s,color,opts){
  return new THREE.Mesh(new THREE.CylinderGeometry(rt,rb,h,s), mat(color,opts));
}
function sphere(r,s,color,opts){
  return new THREE.Mesh(new THREE.SphereGeometry(r,s,s), mat(color,opts));
}
function plane(w,h,color,opts){
  return new THREE.Mesh(new THREE.PlaneGeometry(w,h), mat(color,opts));
}

// ── FLOOR ──
var floorM = new THREE.Mesh(
  new THREE.PlaneGeometry(400,400),
  new THREE.MeshLambertMaterial({color: CFG.floorColor})
);
floorM.rotation.x = -Math.PI/2;
floorM.position.y = 0;
floorM.receiveShadow = true;
scene.add(floorM);

// ── WALLS ──
// Back-left wall
var wallL = plane(300,230,CFG.wallLColor);
wallL.position.set(-150,115,-50);
wallL.receiveShadow = true;
scene.add(wallL);

// Back-right wall
var wallR = plane(300,230,CFG.wallRColor);
wallR.rotation.y = Math.PI/2;
wallR.position.set(150,115,-50);
wallR.receiveShadow = true;
scene.add(wallR);

// Left wall
var leftWall = plane(280,230,CFG.wallLColor);
leftWall.rotation.y = Math.PI/2;
leftWall.position.set(-150,115,90);
leftWall.receiveShadow = true;
scene.add(leftWall);

// Baseboard
function baseboard(w,x,y,z,ry){
  var m = box(w,8,5,0xcccccc);
  m.position.set(x,y,z);
  if(ry) m.rotation.y = ry;
  scene.add(m);
}
baseboard(200,-150,4,-50);
baseboard(140,-150,4,90,Math.PI/2);

// ══════════════════════════════════════════════════════════════
// ROOM-SPECIFIC CONTENT
// ══════════════════════════════════════════════════════════════

// ── LUNA: Pink cozy bedroom ──────────────────────────────────
if(COMP === 'luna') {
  // Window with pink curtains
  var wf = box(160,130,8,0xd4b896); wf.position.set(0,170,-48); scene.add(wf);
  var wg = new THREE.Mesh(new THREE.BoxGeometry(144,118,3), new THREE.MeshBasicMaterial({color:0xfff8e8,transparent:true,opacity:0.85}));
  wg.position.set(0,170,-44); scene.add(wg);
  var divV = box(3,118,5,0xd4b896); divV.position.set(0,170,-43); scene.add(divV);
  var divH = box(144,3,5,0xd4b896); divH.position.set(0,170,-43); scene.add(divH);
  var sill = box(170,12,18,0xd4b896); sill.position.set(0,103,-43); scene.add(sill);
  // Glow
  var gc=document.createElement('canvas');gc.width=256;gc.height=256;
  var gx=gc.getContext('2d');var grd=gx.createRadialGradient(128,128,0,128,128,128);
  grd.addColorStop(0,'rgba(255,230,160,0.9)');grd.addColorStop(0.5,'rgba(255,200,100,0.4)');grd.addColorStop(1,'rgba(255,180,80,0)');
  gx.fillStyle=grd;gx.fillRect(0,0,256,256);
  var glowS=new THREE.Sprite(new THREE.SpriteMaterial({map:new THREE.CanvasTexture(gc),transparent:true,opacity:0.9}));
  glowS.scale.set(320,240,1);glowS.position.set(0,165,-70);scene.add(glowS);
  // Curtains
  var cl=plane(55,175,0xffc8d8,{transparent:true,opacity:0.42,side:THREE.DoubleSide});cl.position.set(-88,105,-48);scene.add(cl);
  var cr=plane(55,175,0xffc8d8,{transparent:true,opacity:0.42,side:THREE.DoubleSide});cr.position.set(88,105,-48);scene.add(cr);
  // Circular rug
  var rug=new THREE.Mesh(new THREE.CircleGeometry(80,48),new THREE.MeshLambertMaterial({color:0xffb8c8,transparent:true,opacity:0.5,side:THREE.DoubleSide}));
  rug.rotation.x=-Math.PI/2;rug.position.set(0,0.2,55);scene.add(rug);
  // Bed
  var bedF=box(185,50,95,0x8B5E3C);bedF.position.set(-20,-25,0);bedF.castShadow=true;bedF.receiveShadow=true;scene.add(bedF);
  var bedH=box(16,85,95,0xff6090);bedH.position.set(-114,18,0);bedH.castShadow=true;scene.add(bedH);
  var bedM=box(168,18,88,0xffffff);bedM.position.set(-18,3,0);bedM.castShadow=true;scene.add(bedM);
  var qc=document.createElement('canvas');qc.width=128;qc.height=128;
  var qx=qc.getContext('2d');
  for(var y=0;y<128;y+=16){for(var x=0;x<128;x+=16){
    qx.fillStyle=(Math.floor(x/16)+Math.floor(y/16))%2===0?'#e8503a':'#ffffff';qx.fillRect(x,y,16,16);
  }}
  var qTex=new THREE.CanvasTexture(qc);qTex.wrapS=qTex.wrapT=THREE.RepeatWrapping;qTex.repeat.set(4,3);
  var quilt=box(163,8,85,0xffffff);quilt.material=new THREE.MeshLambertMaterial({map:qTex});quilt.position.set(-18,13,0);quilt.castShadow=true;scene.add(quilt);
  var wf2=box(163,10,85,0xffffff);wf2.position.set(-18,20,43);wf2.castShadow=true;scene.add(wf2);
  var p1=box(46,12,32,0xfff0f5);p1.position.set(-66,18,-26);p1.castShadow=true;scene.add(p1);
  var p2=box(42,11,30,0xfff0f5);p2.position.set(-30,18,-27);p2.castShadow=true;scene.add(p2);
  // Desk
  var dt=box(135,8,65,0xe0c090);dt.position.set(-115,50,38);dt.castShadow=true;scene.add(dt);
  [[-60,-32],[60,-32],[-60,32],[60,32]].forEach(function(p){
    var lg=box(8,75,8,0x8B5E3C);lg.position.set(-115+p[0],12,38+p[1]);lg.castShadow=true;scene.add(lg);
  });
  var dr=box(52,20,58,0xdcc098);dr.position.set(-153,33,34);dr.castShadow=true;scene.add(dr);
  var pole=box(8,32,8,0xe8e8e8);pole.position.set(-115,59,38);scene.add(pole);
  var mb=box(32,5,22,0xe8e8e8);mb.position.set(-115,42,38);scene.add(mb);
  var mon=box(62,44,4,0xe8e8e8);mon.position.set(-115,77,38);mon.castShadow=true;scene.add(mon);
  var scr=box(56,40,2,0x3a6a9a);scr.position.set(-115,77,40);scene.add(scr);
  var mug=cyl(5,5,10,12,0xffffff);mug.position.set(-88,55,50);scene.add(mug);
  // Chair
  var seat=box(36,6,32,0xfff0f5);seat.position.set(-78,0,62);seat.castShadow=true;scene.add(seat);
  var cbk=box(36,32,6,0xfff0f5);cbk.position.set(-78,19,49);cbk.castShadow=true;scene.add(cbk);
  // Bookshelf
  var sbg=box(52,135,22,0xe0c090);sbg.position.set(105,67,-48);sbg.castShadow=true;sbg.receiveShadow=true;scene.add(sbg);
  [28,58,88,118].forEach(function(y){var sh=box(48,3,20,0xe0c090);sh.position.set(105,y-67,-48);scene.add(sh);});
  var bks1=[[0xff6090,9,24],[0x4a8a5a,8,22],[0x4a6a9a,10,20],[0x8a6a3a,8,23],[0xff80c0,7,21]];
  var bx=-21;bks1.forEach(function(b){
    var bk=box(b[1],b[2],18,b[0]);bk.position.set(105+bx+b[1]/2,1+b[2]/2-67,-48);bk.castShadow=true;scene.add(bk);bx+=b[1]+1;
  });
  var cab=box(48,28,3,0xdcc098);cab.position.set(105,-17,-38);scene.add(cab);
  // Dresser
  var drs=box(72,92,32,0xe0c090);drs.position.set(-125,46,38);drs.castShadow=true;scene.add(drs);
  [74,50,26,2].forEach(function(y){var dd=box(62,18,2,0xdcc098);dd.position.set(-125,y-46,54);scene.add(dd);});
  var drst=box(76,5,36,0xdcc098);drst.position.set(-125,94,38);scene.add(drst);
  var lp=cyl(4,4,32,12,0xffc080);lp.position.set(-141,64,38);scene.add(lp);
  var lg=sphere(9,16,0xffd080,{emissive:0xffd080,emissiveIntensity:2});lg.position.set(-141,83,38);scene.add(lg);
  var pot=cyl(6,5,9,12,0xc49464);pot.position.set(-105,50,38);scene.add(pot);
  var lf=sphere(7,12,0x6aaa5a);lf.position.set(-105,57,38);lf.scale.y=1.3;scene.add(lf);
  // Nightstand
  var ns=box(32,42,28,0xe0c090);ns.position.set(50,21,2);ns.castShadow=true;scene.add(ns);
  var nt=box(36,5,32,0xdcc098);nt.position.set(50,43,2);scene.add(nt);
  var clk=sphere(8,16,0xffa000);clk.position.set(50,52,2);scene.add(clk);
  // Wall clock
  var wclk=new THREE.Mesh(new THREE.CylinderGeometry(15,15,3,32),mat(0xffffff));wclk.rotation.x=Math.PI/2;wclk.position.set(65,175,-48);scene.add(wclk);
  // Gallery
