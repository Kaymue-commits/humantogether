  var miloHair=sphere(16,16,0x60a040);miloHair.scale.set(1.1,1,1.1);miloHair.position.y=44;miloG.add(miloHair);
  [5,-5].forEach(function(x){var e=sphere(2.8,8,0x40a020,{emissive:0x308010,emissiveIntensity:0.5});e.position.set(x,43,13);miloG.add(e);});
  [[-4,44,14],[6,44,14]].forEach(function(p){var h=sphere(1.2,6,0xffffff);h.position.set(p[0],p[1],p[2]);miloG.add(h);});
  var mmth=new THREE.Mesh(new THREE.TorusGeometry(2.5,0.8,8,16,Math.PI),mat(0x80a060));mmth.position.set(0,38,14);mmth.rotation.x=Math.PI;miloG.add(mmth);
  [[-16,19,0],[16,19,0]].forEach(function(p,i){var a=cyl(3,3,15,8,0x80c060);a.position.set(p[0],p[1],p[2]);a.rotation.z=i===0?0.4:-0.4;miloG.add(a);});
  var mBody=sphere(11,16,0x90d070);mBody.scale.set(1.2,0.8,1.2);mBody.position.y=8;miloG.add(mBody);
  miloG.position.set(0,0,55);miloG.castShadow=true;scene.add(miloG);
}

// ── SAGE: Dark classic study ─────────────────────────────────
if(COMP === 'sage') {
  // Window with night sky
  var wf=box(160,130,8,0x2a1a0a);wf.position.set(0,170,-48);scene.add(wf);
  var wg=new THREE.Mesh(new THREE.BoxGeometry(144,118,3),new THREE.MeshBasicMaterial({color:0x080820}));
  wg.position.set(0,170,-44);scene.add(wg);
  // Stars outside
  var skyCanvas=document.createElement('canvas');skyCanvas.width=256;skyCanvas.height=256;
  var skc=skyCanvas.getContext('2d');
  skc.fillStyle='#080820';skc.fillRect(0,0,256,256);
  for(var i=0;i<60;i++){
    var sx=Math.random()*240;var sy=Math.random()*180;
    var ss=0.5+Math.random()*2;
    skc.fillStyle='rgba(255,255,240,'+(0.4+Math.random()*0.6)+')';
    skc.beginPath();skc.arc(sx,sy,ss,0,Math.PI*2);skc.fill();
  }
  skc.fillStyle='rgba(200,180,100,0.9)';skc.beginPath();skc.arc(180,30,15,0,Math.PI*2);skc.fill();
  var skyTex=new THREE.CanvasTexture(skyCanvas);
  var skyMesh=new THREE.Mesh(new THREE.PlaneGeometry(140,114),new THREE.MeshBasicMaterial({map:skyTex}));
  skyMesh.position.set(0,170,-42);scene.add(skyMesh);
  var divV=box(3,118,5,0x2a1a0a);divV.position.set(0,170,-43);scene.add(divV);
  var divH=box(144,3,5,0x2a1a0a);divH.position.set(0,170,-43);scene.add(divH);
  // Dark floor
  // Desk with green lamp
  var dsk3=box(140,8,70,0x3a2010);dsk3.position.set(-110,52,38);dsk3.castShadow=true;scene.add(dsk3);
  [[-62,-32],[62,-32],[-62,32],[62,32]].forEach(function(p){
    var lg3=box(8,75,8,0x2a1508);lg3.position.set(-110+p[0],14,38+p[1]);lg3.castShadow=true;scene.add(lg3);
  });
  // Books everywhere
  var libB=box(80,150,25,0x2a1a10);libB.position.set(110,75,-48);libB.castShadow=true;scene.add(libB);
  [30,60,90,120].forEach(function(y){var sh3=box(76,3,23,0x3a2515);sh3.position.set(110,y-75,-48);scene.add(sh3);});
  var libBks=[[0x8B4513,10,28],[0x2a4a2a,9,26],[0x4a3020,11,24],[0x8B0000,8,27],[0x2a2a6a,10,25],[0x4a3a10,9,23],[0x6a2a2a,8,26],[0x1a3a4a,10,24],[0x5a3a1a,9,22],[0x3a1a3a,8,25]];
  var libY=[27,57,87,117];
  libY.forEach(function(ly,li){
    var lbx=-95;
    for(var bi=0;bi<4;bi++){
      var b=libBks[(li*4+bi)%libBks.length];
      var bk3=box(b[1],b[2],22,b[0]);bk3.position.set(110+lbx+b[1]/2,b[2]/2-75+ly,-48);bk3.castShadow=true;scene.add(bk3);lbx+=b[1]+1;
    }
  });
  // Lamp
  var lmpBase=cyl(8,12,6,16,0x2a4010);lmpBase.position.set(-80,56,15);scene.add(lmpBase);
  var lmpPole=cyl(3,3,50,12,0x1a3010);lmpPole.position.set(-80,82,15);scene.add(lmpPole);
  var lmpShade=cyl(15,8,20,16,0x3a5020);lmpShade.position.set(-80,107,15);scene.add(lmpShade);
  var lampGlow=new THREE.PointLight(0x80ff40,0.8,80);lampGlow.position.set(-80,100,15);scene.add(lampGlow);
  var lmpBulb=sphere(5,12,0xffd060,{emissive:0xffc040,emissiveIntensity:3});lmpBulb.position.set(-80,98,15);scene.add(lmpBulb);
  // Leather chair
  var lSeat=box(40,8,38,0x4a2010);lSeat.position.set(-72,0,62);lSeat.castShadow=true;scene.add(lSeat);
  var lBkg=box(40,50,8,0x4a2010);lBkg.position.set(-72,27,47);lBkg.castShadow=true;scene.add(lBkg);
  var lArms=box(8,20,8,0x3a1808);lArms.position.set(-96,10,55);scene.add(lArms);
  // Sage character
  var sageG=new THREE.Group();
  sageG.add(sphere(13,16,0x8a6040));sageG.children[0].scale.set(1,1.1,1);sageG.children[0].position.y=20;
  var sageHead=sphere(15,16,0xf0e8d8);sageHead.position.y=41;sageG.add(sageHead);
  var sageHair=sphere(16,16,0x3a2010);sageHair.scale.set(1.1,1,1.1);sageHair.position.y=43;sageG.add(sageHair);
  [5,-5].forEach(function(x){var e=sphere(2.8,8,0x604020,{emissive:0x402010,emissiveIntensity:0.3});e.position.set(x,43,13);sageG.add(e);});
  [[-4,44,14],[6,44,14]].forEach(function(p){var h=sphere(1.2,6,0xffffff);h.position.set(p[0],p[1],p[2]);sageG.add(h);});
  var smth=new THREE.Mesh(new THREE.TorusGeometry(2.5,0.8,8,16,Math.PI),mat(0x8a6040));smth.position.set(0,38,14);smth.rotation.x=Math.PI;sageG.add(smth);
  [[-16,19,0],[16,19,0]].forEach(function(p,i){var a=cyl(3,3,15,8,0x8a6040);a.position.set(p[0],p[1],p[2]);a.rotation.z=i===0?0.4:-0.4;sageG.add(a);});
  var sBody=sphere(11,16,0x9a7050);sBody.scale.set(1.2,0.8,1.2);sBody.position.y=8;sageG.add(sBody);
  var sBook=box(8,12,3,0x4a3020);sBook.position.set(11,50,6);sBook.rotation.z=0.3;sageG.add(sBook);
  var sGlasses=box(16,3,2,0x3a2010);sGlasses.position.set(0,44,14);sageG.add(sGlasses);
  sageG.position.set(0,0,60);sageG.castShadow=true;scene.add(sageG);
}

// ── ANIMATION ──
var time=0;
function animate(){
  requestAnimationFrame(animate);
  time+=0.016;
  // Gentle character bob (find the character group)
  scene.traverse(function(obj){
    if(obj.isMesh && obj.geometry && obj.geometry.type === 'SphereGeometry'){
      if(obj.material && obj.material.color){
        var c=obj.material.color.getHex();
        if(c===0xffb8c8||c===0x4060a0||c===0xffb840||c===0x80c060||c===0x8a6040){
          if(obj.position.y>30){ // it's a character head/body
            obj.parent.position.y=Math.sin(time*0.7)*2;
          }
        }
      }
    }
  });
  renderer.render(scene,camera);
}
animate();

// Hide loading
setTimeout(function(){
  document.getElementById('loading').classList.add('hide');
  setTimeout(function(){try{document.getElementById('loading').remove()}catch(e){}},1200);
},1000);

// ── CHAT ──
document.title=(names[COMP]||COMP)+'的房间 · 共生境';

function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}
function sendMsg(){
  var inp=document.getElementById('chatInput');
  var msgs=document.getElementById('chatMsgs');
  if(!inp||!inp.value.trim())return;
  var t=inp.value.trim();
  msgs.innerHTML+='<div class="msg user"><span class="mt">'+esc(t)+'</span></div>';
  inp.value='';msgs.scrollTop=msgs.scrollHeight;
  var tid='t'+Date.now();
  msgs.innerHTML+='<div class="msg ai" id="'+tid+'"><span class="mt" style="font-style:italic">思考中...</span></div>';
  msgs.scrollTop=msgs.scrollHeight;
  fetch('/api/chat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({message:t,companion:COMP})})
  .then(function(r){return r.json()})
  .then(function(d){
    var el=document.getElementById(tid);
    if(el)el.innerHTML='<span class="mt">'+esc(d.text||'...').replace(/\n/g,'<br>')+'</span>';
    msgs.scrollTop=msgs.scrollHeight;
  })
  .catch(function(){
    var el=document.getElementById(tid);
    if(el)el.innerHTML='<span class="mt">网络有点问题，稍等～</span>';
    msgs.scrollTop=msgs.scrollHeight;
  });
}
</script>
</body>
</html>
