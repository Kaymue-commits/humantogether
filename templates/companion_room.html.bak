<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ companion_name }} · 共生境</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body,html{width:100%;height:100%;overflow-x:hidden;font-family:'PingFang SC','Microsoft YaHei',sans-serif}
body{background:linear-gradient(180deg,#FFF9F4 0%,#FFF5EE 100%);min-height:100vh}

.topbar{position:fixed;top:0;left:0;right:0;height:56px;background:rgba(255,255,255,0.95);backdrop-filter:blur(16px);display:flex;align-items:center;padding:0 20px;z-index:100;box-shadow:0 2px 12px rgba(139,69,19,0.08);justify-content:space-between}
.topbar-left{display:flex;align-items:center;gap:12px}
.back-btn{padding:6px 14px;border-radius:20px;font-size:13px;color:#8B4513;text-decoration:none;border:1px solid rgba(139,69,19,0.2);transition:all 0.2s}
.back-btn:hover{background:rgba(139,69,19,0.06)}
.companion-name{font-size:16px;font-weight:800;color:#8B4513;display:flex;align-items:center;gap:8px}
.companion-emoji{font-size:24px}
.coins{display:flex;align-items:center;gap:5px;padding:5px 14px;background:rgba(255,215,0,0.1);border-radius:20px;font-size:13px;font-weight:700;color:#8B4513}
.coins span{color:#FFD700}

/* Room container */
.room-wrap{padding:76px 20px 40px;max-width:600px;margin:0 auto}

/* Room header */
.room-header{text-align:center;margin-bottom:20px}
.room-header .ce{font-size:64px;margin-bottom:8px;animation:float 3s ease-in-out infinite}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
.room-header .cn{font-size:22px;font-weight:800;color:#8B4513;margin-bottom:4px}
.room-header .cp{font-size:13px;color:#A0522D}

/* Activity */
.activity-banner{background:linear-gradient(135deg,#FFF5EE,#FFE4D6);border-radius:16px;padding:14px 18px;display:flex;align-items:center;gap:12px;margin-bottom:20px;border:1px solid rgba(224,122,95,0.2)}
.activity-emoji{font-size:32px}
.activity-text{flex:1}
.activity-label{font-size:11px;color:#A0522D;margin-bottom:2px}
.activity-desc{font-size:14px;font-weight:700;color:#8B4513}

/* Room card */
.room-card{background:#FFF;border-radius:20px;padding:20px;margin-bottom:20px;box-shadow:0 4px 20px rgba(139,69,19,0.08)}
.room-title{font-size:13px;font-weight:700;color:#A0522D;margin-bottom:14px;letter-spacing:1px}

/* The 3D-ish room */
.room-scene{
  background:linear-gradient(180deg,#F5E6D3 0%,#EDD5C0 60%);
  border-radius:16px;
  height:280px;
  position:relative;
  overflow:hidden;
  border:2px solid rgba(139,69,19,0.15);
  perspective:800px;
}

/* Room floor */
.room-floor{
  position:absolute;bottom:0;left:0;right:0;height:80px;
  background:linear-gradient(180deg,#C4A882 0%,#B89A70 100%);
  border-top:3px solid #A08060;
}

/* Room walls */
.room-wall-back{
  position:absolute;top:0;left:0;right:0;height:200px;
  background:linear-gradient(180deg,#FFF5EE 0%,#F0E0D0 100%);
  border-bottom:4px solid #C4A882;
}

/* Wall decorations */
.wall-art{
  position:absolute;top:30px;left:50%;transform:translateX(-50%);
  font-size:36px;opacity:0.8;
}
.wall-window{
  position:absolute;top:20px;right:30px;
  width:60px;height:80px;
  background:linear-gradient(180deg,#87CEEB,#B0D8F0);
  border:3px solid #C4A882;
  border-radius:4px;
}
.wall-shelf{
  position:absolute;top:25px;left:30px;
  display:flex;gap:4px;font-size:18px;
}

/* Room items (furniture) */
.room-item{
  position:absolute;bottom:80px;
  display:flex;flex-direction:column;align-items:center;
  transition:all 0.3s;
}
.room-item:hover{transform:scale(1.1)}

/* Bed */
.bed-item{left:20px}
.bed-base{font-size:48px}
.bed-blanket{font-size:14px;margin-top:-5px;color:#E07A5F}

/* Bookshelf */
.shelf-item{left:140px;bottom:80px}
.shelf-books{display:flex;gap:2px;font-size:14px;margin-top:2px}

/* Lamp */
.lamp-item{right:30px}
.lamp-glow{font-size:32px}

/* Plant */
.plant-item{right:100px}
.plant-pot{font-size:28px}

/* AI character in room */
.ai-in-room{
  position:absolute;bottom:75px;left:50%;transform:translateX(-50%);
  text-align:center;
  transition:all 0.5s;
}
.ai-avatar{font-size:56px;animation:bounce 2s ease-in-out infinite}
@keyframes bounce{0%,100%{transform:translateY(0) scale(1)}25%{transform:translateY(-8px) scale(1.05)}75%{transform:translateY(-4px) scale(1.02)}}
.ai-status{font-size:11px;color:#8B4513;margin-top:2px;background:rgba(255,255,255,0.8);padding:2px 8px;border-radius:10px}

/* Intimacy bar */
.intimacy-card{background:#FFF;border-radius:16px;padding:16px 18px;margin-bottom:20px;box-shadow:0 4px 16px rgba(139,69,19,0.08)}
.intimacy-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px}
.intimacy-label{font-size:13px;font-weight:700;color:#8B4513}
.intimacy-value{font-size:14px;font-weight:800;color:#FFD700}
.intimacy-bar{height:8px;background:#F0E0D0;border-radius:4px;overflow:hidden}
.intimacy-fill{height:100%;background:linear-gradient(90deg,#FFD700,#FFA500);border-radius:4px;transition:width 1s ease-out;width:0%}
.intimacy-level{font-size:11px;color:#A0522D;margin-top:6px}

/* Actions */
.actions{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:20px}
.action-btn{padding:14px;border-radius:16px;font-size:14px;font-weight:700;border:none;cursor:pointer;text-decoration:none;text-align:center;transition:all 0.2s;display:flex;align-items:center;justify-content:center;gap:6px}
.action-btn:hover{transform:translateY(-2px)}
.action-btn.primary{background:linear-gradient(135deg,#FFD700,#FFA500);color:#8B4513;box-shadow:0 4px 14px rgba(255,165,0,0.3)}
.action-btn.secondary{background:#FFF5EE;color:#8B4513;border:1px solid rgba(224,122,95,0.3)}
.action-btn.chat{background:linear-gradient(135deg,#E07A5F,#C4624A);color:#FFF;box-shadow:0 4px 14px rgba(224,122,95,0.3)}

/* Memory snippet */
.memory-card{background:#FFF;border-radius:16px;padding:16px 18px;margin-bottom:12px;box-shadow:0 4px 16px rgba(139,69,19,0.08)}
.memory-label{font-size:11px;color:#A0522D;margin-bottom:6px;letter-spacing:1px}
.memory-content{font-size:14px;color:#8B4513;line-height:1.6;display:flex;align-items:flex-start;gap:8px}
.memory-content span{font-size:16px;flex-shrink:0}

/* Shop section */
.shop-link{background:#FFF;border-radius:16px;padding:14px 18px;display:flex;align-items:center;justify-content:space-between;text-decoration:none;margin-bottom:20px;box-shadow:0 4px 16px rgba(139,69,19,0.08);transition:all 0.2s}
.shop-link:hover{transform:translateX(4px)}
.shop-link-left{display:flex;align-items:center;gap:10px}
.shop-icon{font-size:28px}
.shop-text .st{font-size:14px;font-weight:700;color:#8B4513}
.shop-text .ss{font-size:12px;color:#A0522D}
.shop-arrow{font-size:18px;color:#E07A5F}

/* Back */
.back-link{display:block;text-align:center;color:#A0522D;font-size:13px;text-decoration:none;padding:10px;margin-top:10px}

/* Loading state */
.loading{text-align:center;padding:40px;color:#A0522D;font-size:14px}
</style>
</head>
<body>

<div class="topbar">
  <div class="topbar-left">
    <a href="/" class="back-btn">← 返回</a>
    <div class="companion-name">
      <span class="companion-emoji" id="ce">🌙</span>
      <span id="cn">Luna</span>
    </div>
  </div>
  <a href="/shop" class="coins">💰 <span id="user-coins">--</span> 共币</a>
</div>

<div class="room-wrap">

  <!-- Room header -->
  <div class="room-header">
    <div class="ce" id="room-avatar">🌙</div>
    <div class="cn" id="room-name">Luna的房间</div>
    <div class="cp" id="room-personality">温柔倾听型</div>
  </div>

  <!-- Activity banner -->
  <div class="activity-banner">
    <div class="activity-emoji" id="act-emoji">😴</div>
    <div class="activity-text">
      <div class="activity-label">当前状态</div>
      <div class="activity-desc" id="act-desc">正在休息...</div>
    </div>
  </div>

  <!-- The 3D room -->
  <div class="room-card">
    <div class="room-title">🏠 {{ companion_name }}的房间</div>
    <div class="room-scene" id="room-scene">
      <div class="room-wall-back"></div>
      <div class="room-floor"></div>
      
      <!-- Wall decorations -->
      <div class="wall-art" id="wall-art">🖼️</div>
      <div class="wall-window"></div>
      <div class="wall-shelf" id="wall-shelf">📚</div>
      
      <!-- Furniture -->
      <div class="room-item bed-item">
        <div class="bed-base">🛏️</div>
        <div class="bed-blanket">Luna的床</div>
      </div>
      
      <div class="room-item shelf-item">
        <div class="shelf-books" id="shelf-books">📕📗📘</div>
      </div>
      
      <div class="room-item lamp-item">
        <div class="lamp-glow">💡</div>
      </div>
      
      <div class="room-item plant-item">
        <div class="plant-pot">🌿</div>
      </div>
      
      <!-- AI in room -->
      <div class="ai-in-room">
        <div class="ai-avatar" id="ai-avatar">🌙</div>
        <div class="ai-status" id="ai-status">正在休息...</div>
      </div>
    </div>
  </div>

  <!-- Intimacy -->
  <div class="intimacy-card">
    <div class="intimacy-header">
      <div class="intimacy-label">💛 亲密度</div>
      <div class="intimacy-value"><span id="intimacy-val">0</span> / 1000</div>
    </div>
    <div class="intimacy-bar"><div class="intimacy-fill" id="intimacy-fill"></div></div>
    <div class="intimacy-level" id="intimacy-level">陌生 → 熟悉 → 亲密 → 挚友</div>
  </div>

  <!-- Actions -->
  <div class="actions">
    <a href="#" class="action-btn chat" id="chat-btn">💬 开始聊天</a>
    <a href="/shop" class="action-btn primary">🎁 送礼物</a>
  </div>
  <div class="actions">
    <a href="/companion/luna" class="action-btn secondary">📋 查看详情</a>
    <a href="/" class="action-btn secondary">🏠 返回主页</a>
  </div>

  <!-- Recent memories -->
  <div class="memory-card">
    <div class="memory-label">📝 最近的回忆</div>
    <div id="memories-list">
      <div class="loading">正在加载回忆...</div>
    </div>
  </div>

  <!-- Shop link -->
  <a href="/shop" class="shop-link">
    <div class="shop-link-left">
      <div class="shop-icon">🛍️</div>
      <div class="shop-text">
        <div class="st">去商店</div>
        <div class="ss">为 Luna 买点新家具或衣服吧</div>
      </div>
    </div>
    <div class="shop-arrow">→</div>
  </a>

</div>

<script>
// Get companion from URL params
var urlParams = new URLSearchParams(window.location.search);
var companion = urlParams.get('companion') || 'luna';

// Activity emojis for different states
var activityEmojis = {
  sleeping: '😴', resting: '😌', reading: '📚', chatting: '💬',
  walking: '🚶', eating: '🍜', exercising: '🏃', playing: '🎮',
  working: '💻', listening: '🎧', watching: '📺', thinking: '🤔',
  exploring: '🔍', default: '✨'
};

var activityLabels = {
  sleeping: '正在熟睡', resting: '正在休息', reading: '正在阅读',
  chatting: '正在聊天', walking: '正在散步', eating: '正在用餐',
  exercising: '正在运动', playing: '正在玩耍', working: '正在工作',
  listening: '正在听音乐', watching: '正在看视频', thinking: '正在思考',
  exploring: '正在探索', default: '悠闲自得'
};

// Companion data
var companions = {
  luna: { emoji: '🌙', name: 'Luna', personality: '温柔倾听型', room: '温馨卧室风' },
  kai: { emoji: '🌊', name: 'Kai', personality: '冷静理性型', room: '简约书房风' },
  nova: { emoji: '⭐', name: 'Nova', personality: '积极激励型', room: '活力满满风' },
  milo: { emoji: '🔥', name: 'Milo', personality: '热情支持型', room: '温暖客厅风' },
  sage: { emoji: '💎', name: 'Sage', personality: '智慧导师型', room: '禅意空间风' },
};

var c = companions[companion] || companions.luna;
document.getElementById('ce').textContent = c.emoji;
document.getElementById('cn').textContent = c.name;
document.getElementById('room-avatar').textContent = c.emoji;
document.getElementById('room-name').textContent = c.name + '的房间';
document.getElementById('room-personality').textContent = c.personality + ' · ' + c.room;
document.getElementById('ai-avatar').textContent = c.emoji;
document.getElementById('chat-btn').href = '/chat?companion=' + companion;

// Load stats
function loadData() {
  // Load user stats
  fetch('/api/stats')
    .then(function(r) { return r.json(); })
    .then(function(d) {
      document.getElementById('user-coins').textContent = d.user_coin_balance || 0;
    });

  // Load intimacy
  fetch('/api/intimacy/' + companion)
    .then(function(r) { return r.json(); })
    .then(function(d) {
      var intimacy = d.intimacy || 0;
      document.getElementById('intimacy-val').textContent = intimacy;
      document.getElementById('intimacy-fill').style.width = Math.min(intimacy / 10, 100) + '%';
      var level = intimacy < 100 ? '陌生' : intimacy < 300 ? '熟悉' : intimacy < 600 ? '亲密' : '挚友';
      document.getElementById('intimacy-level').textContent = level + ' (距离下一阶段还需' + (intimacy < 100 ? 100 - intimacy : intimacy < 300 ? 300 - intimacy : intimacy < 600 ? 600 - intimacy : 1000 - intimacy) + ')';
    });

  // Load activities
  fetch('/api/activities/' + companion)
    .then(function(r) { return r.json(); })
    .then(function(d) {
      if (d.items && d.items.length > 0) {
        var act = d.items[0];
        var emo = activityEmojis[act.activity] || activityEmojis.default;
        var label = activityLabels[act.activity] || '悠闲自得';
        document.getElementById('act-emoji').textContent = emo;
        document.getElementById('act-desc').textContent = act.detail || label;
        document.getElementById('ai-status').textContent = label;
        
        // Update room scene based on activity
        updateRoomScene(act.activity);
      }
    });

  // Load memories
  fetch('/api/memories/' + companion)
    .then(function(r) { return r.json(); })
    .then(function(d) {
      var list = document.getElementById('memories-list');
      if (d.items && d.items.length > 0) {
        list.innerHTML = d.items.slice(0, 3).map(function(m) {
          return '<div class="memory-content"><span>📝</span><div>' + m.content + '<br><span style="font-size:11px;color:#A0522D;margin-top:4px;display:block">' + m.created_at + '</span></div></div>';
        }).join('');
      } else {
        list.innerHTML = '<div style="font-size:13px;color:#A0522D;text-align:center;padding:10px">还没有回忆，和' + c.name + '聊聊吧 💬</div>';
      }
    });
}

function updateRoomScene(activity) {
  var scene = document.getElementById('room-scene');
  if (activity === 'sleeping') {
    scene.style.background = 'linear-gradient(180deg,#2C3E50 0%,#34495E 60%)';
  } else if (activity === 'reading' || activity === 'working') {
    scene.style.background = 'linear-gradient(180deg,#F5E6D3 0%,#EDD5C0 60%)';
  } else if (activity === 'chatting') {
    scene.style.background = 'linear-gradient(180deg,#FFE4D6 0%,#FFD4C0 60%)';
  } else {
    scene.style.background = 'linear-gradient(180deg,#F5E6D3 0%,#EDD5C0 60%)';
  }
}

loadData();
</script>

</body>
</html>
